DATABASE_URL=postgres://gather:gather@localhost:5432/gather
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
ADMIN_SECRET=change-me-in-prod

# Resend transactional email
# Get your API key at https://resend.com/api-keys
# Leave RESEND_API_KEY blank in dev to print emails to the server log instead of sending.
RESEND_API_KEY=
EMAIL_FROM=Gather <hello@gather.app>

# Daily.co video rooms
# Get your API key at https://dashboard.daily.co/developers
# Leave blank in dev to use a placeholder Whereby link instead.
DAILY_API_KEY=
